      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMorthalFaction\") or is_in_faction(actorUUID, \"GuardFactionMorthal\")",
        "content": "Movarth's Lair is a cave system north of Morthal where the master vampire Movarth Piquine holds court. Alva of Morthal serves him — and the town's recent fire was his doing.",
        "display_name": "Movarth's Lair",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "dungeon.hjaalmarch.movarths_lair",
        "location": "",
        "tags": [
          "Movarth's Lair",
          "vampires",
          "Hjaalmarch",
