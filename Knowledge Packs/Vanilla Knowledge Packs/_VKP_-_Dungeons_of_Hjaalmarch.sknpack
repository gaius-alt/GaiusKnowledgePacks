    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMorthalFaction\") or is_in_faction(actorUUID, \"GuardFactionMorthal\")",
        "content": "Ustengrav is the great Nordic ruin north of Morthal, sealed for centuries with the Horn of Jurgen Windcaller at its heart — until thieves and a different hand reached for it.",
        "display_name": "Ustengrav",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.hjaalmarch.ustengrav",
        "location": "",
        "tags": [
          "Ustengrav",
          "Nordic ruin",
          "Hjaalmarch",
          "Horn of Jurgen Windcaller",
          "Greybeards",
          "draugr"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMorthalFaction\") or is_in_faction(actorUUID, \"GuardFactionMorthal\")",
        "content": "Folgunthur is the Nordic crypt of Mikrul Gauldurson — first of three tombs holding the murderous sons of Gauldur. His amulet fragment lies among the draugr beyond his coffin.",
        "display_name": "Folgunthur",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "dungeon.hjaalmarch.folgunthur",
        "location": "",
        "tags": [
