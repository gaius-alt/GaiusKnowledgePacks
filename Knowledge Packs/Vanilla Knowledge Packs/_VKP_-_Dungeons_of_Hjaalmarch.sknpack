{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Marshland tombs, ruins, and bandit hideouts across Hjaalmarch — including Ustengrav and Movarth's Lair.",
    "entry_count": 10,
    "exported_at": "2026-05-18T04:54:36Z",
    "format_version": 2,
    "name": "_VKP - Dungeons of Hjaalmarch",
