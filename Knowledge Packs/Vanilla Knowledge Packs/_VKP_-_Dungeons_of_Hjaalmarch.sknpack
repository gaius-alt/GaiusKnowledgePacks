        "condition_expr": "is_in_faction(actorUUID, \"TownMorthalFaction\") or is_in_faction(actorUUID, \"GuardFactionMorthal\")",
        "content": "Stonehills is a small iron-mining settlement in Hjaalmarch run by Sorli the Builder — workers and a small mine, supplying ore to the Stormcloak war effort.",
        "display_name": "Stonehills",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "dungeon.hjaalmarch.stonehills",
        "location": "",
        "tags": [
