      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Shadowgreen Cavern is a hidden cave on Haafingar's northern coast — sun filters through a hole in the roof onto a small grove of trees, tended by spriggans and prowled by sabre cats.",
        "display_name": "Shadowgreen Cavern",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.haafingar.shadowgreen_cavern",
