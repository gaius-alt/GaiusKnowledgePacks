        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Broken Oar Grotto is a pirate-held sea cave on the western coast of Haafingar — the Blood Horkers, led by Stig Salt-Plank, make port here when the East Empire ships are running rich.",
        "display_name": "Broken Oar Grotto",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.haafingar.broken_oar_grotto",
