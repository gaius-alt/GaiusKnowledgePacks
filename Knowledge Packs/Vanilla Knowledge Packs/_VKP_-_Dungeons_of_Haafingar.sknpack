      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Dragon Bridge is the small settlement south of Solitude built around the great stone bridge carved with a dragon's head — the Penitus Oculatus has its outpost here under Commander Maro.",
