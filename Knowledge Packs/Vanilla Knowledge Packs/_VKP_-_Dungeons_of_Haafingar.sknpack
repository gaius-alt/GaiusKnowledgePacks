      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Pinemoon Cave is a vampire lair in the Haafingar mountains northwest of Dragon Bridge — a small cave where a coven of vampires feeds far from the city's notice.",
