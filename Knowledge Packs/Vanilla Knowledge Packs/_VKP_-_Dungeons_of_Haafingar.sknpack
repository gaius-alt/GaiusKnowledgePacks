{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Nordic tombs, Thalmor strongholds, sea caves, and bandit forts of Haafingar — including Volskygge, Northwatch Keep, and the Statue of Meridia at Kilkreath.",
    "entry_count": 12,
    "exported_at": "2026-05-18T04:54:36Z",
    "format_version": 2,
    "name": "_VKP - Dungeons of Haafingar",
    "npc_groups": [],
    "version": "1.0.0",
    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Volskygge is the great Nordic ruin in the western Haafingar mountains. The dragon priest Volsung waits behind the deep chamber's door — his mask resting on the bier behind him.",
        "display_name": "Volskygge",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.haafingar.volskygge",
        "location": "",
        "tags": [
          "Volskygge",
          "Nordic ruin",
          "Haafingar",
          "Dragon Priest",
          "mask",
          "Whirlwind Sprint"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Kilkreath Ruins lies beneath the great Statue of Meridia west of Solitude — Malkoran the necromancer holds the temple, and Meridia herself calls for him to be ended and Dawnbreaker taken from her altar.",
        "display_name": "Kilkreath Ruins (Meridia's Temple)",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.haafingar.kilkreath_ruins",
        "location": "",
        "tags": [
          "Kilkreath Ruins",
          "Meridia",
          "Statue of Meridia",
          "Haafingar",
          "Malkoran",
          "Dawnbreaker",
          "necromancers"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Wolfskull Cave overlooks the sea west of Solitude — necromancers have made it the focus of a ritual to call Potema, the Wolf Queen, back from Sovngarde.",
        "display_name": "Wolfskull Cave",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "dungeon.haafingar.wolfskull_cave",
        "location": "",
        "tags": [
          "Wolfskull Cave",
          "Haafingar",
          "Potema",
          "necromancers",
          "Wolf Queen",
          "ritual",
          "Falk Firebeard"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Northwatch Keep is the Thalmor fortress on the northern coast of Haafingar — Justiciars run interrogations here, and prisoners like Thorald Gray-Mane vanish behind its walls.",
        "display_name": "Northwatch Keep",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.haafingar.northwatch_keep",
        "location": "",
        "tags": [
          "Northwatch Keep",
          "Thalmor",
          "Haafingar",
          "Justiciar",
          "Thorald Gray-Mane",
          "prisoners",
          "fortress"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Brinewater Grotto is a sea cave under the cliffs of Solitude — Jaree-Ra's Blackblood Marauders use it as their base, stockpiling cargo plundered from ships they lured onto the rocks.",
        "display_name": "Brinewater Grotto",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.haafingar.brinewater_grotto",
        "location": "",
        "tags": [
          "Brinewater Grotto",
          "Haafingar",
          "Blackblood Marauders",
          "wreckers",
          "Jaree-Ra",
          "Lights Out"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Lost Echo Cave is a Falmer-held warren in the western Haafingar mountains — built into a half-buried Dwemer outpost. Falmer patrol the tunnels and nests of chaurus skitter through the dark.",
        "display_name": "Lost Echo Cave",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.haafingar.lost_echo_cave",
        "location": "",
        "tags": [
          "Lost Echo Cave",
          "Haafingar",
          "Falmer",
          "Dwemer",
          "chaurus"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "The Solitude Lighthouse guides ships through the rocks below the cliff city. Its keeper Ma'jhad has been targeted by Alik'r wreckers who want the light snuffed.",
        "display_name": "Solitude Lighthouse",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.haafingar.solitude_lighthouse",
        "location": "",
        "tags": [
          "Solitude Lighthouse",
          "Haafingar",
          "Jaree-Ra",
          "Ma'jhad",
          "keeper",
          "Lights Out"
