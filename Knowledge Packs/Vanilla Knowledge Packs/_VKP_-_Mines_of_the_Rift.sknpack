        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Northwind Mine is a small abandoned iron mine in the eastern Rift mountains — the veins thinned out, the miners left, and the place is now used as occasional bandit shelter.",
