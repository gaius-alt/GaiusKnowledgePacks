        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Cicero is the eccentric Keeper of the Night Mother, who transported her corpse from the ruined Cheydinhal Sanctuary to Falkreath. Bursting with manic energy and unwavering devotion, he speaks to the Night Mother as if she answers back.",
        "display_name": "Cicero - Keeper of the Night Mother",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "falkreath.people.cicero",
