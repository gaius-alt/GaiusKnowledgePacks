      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Valdr is a hunter recovering at the Dead Man's Drink after a werewolf attack left him badly wounded. He knows the location of Sinding's lair and will pass that information to anyone brave enough to pursue the beast.",
        "display_name": "Valdr - Injured Hunter",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "falkreath.people.valdr",
