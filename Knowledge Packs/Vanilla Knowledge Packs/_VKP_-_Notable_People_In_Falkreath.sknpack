      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Astrid is the leader of the Falkreath Dark Brotherhood Sanctuary, having taken control after the previous Listener failed to hear the Night Mother. Pragmatic, ruthless, and fiercely protective of her family of assassins.",
        "display_name": "Astrid - Dark Brotherhood Leader",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "falkreath.people.astrid",
