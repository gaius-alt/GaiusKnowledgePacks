        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Babette appears to be a young girl but is in fact a vampire over 300 years old, serving as the Dark Brotherhood Sanctuary's alchemist in Falkreath. Her innocent looks hide centuries of deadly experience.",
        "display_name": "Babette - Dark Brotherhood Alchemist",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "falkreath.people.babette",
