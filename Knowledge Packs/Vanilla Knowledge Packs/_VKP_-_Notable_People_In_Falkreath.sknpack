        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Delacourt is a Redguard bouncer at the Dead Man's Drink, hired by Valga Vinicia to keep rowdy patrons in line. He's a quiet, watchful presence who rarely speaks but never misses a thing.",
        "display_name": "Delacourt - Dead Man's Drink Bouncer",
        "emotion": "",
        "importance": 0.5,
        "knowledge_key": "falkreath.people.delacourt",
