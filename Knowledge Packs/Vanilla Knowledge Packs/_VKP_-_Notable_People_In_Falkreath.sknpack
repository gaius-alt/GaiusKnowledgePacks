      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Narri is Valga Vinicia's daughter, a young Imperial who works the floor at the Dead Man's Drink. She keeps the inn running smoothly alongside her sharp-witted mother.",
        "display_name": "Narri - Dead Man's Drink",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "falkreath.people.narri",
