      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Sinding is a Nord werewolf locked in Falkreath's Barracks for killing a child during a cursed transformation. He wears the Ring of Hircine and is the central figure in the Daedric quest the people of Falkreath whisper about.",
        "display_name": "Sinding - The Werewolf of Falkreath",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "falkreath.people.sinding",
        "location": "",
        "tags": [
          "Sinding",
