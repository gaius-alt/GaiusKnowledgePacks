        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Arcturus is a member of the Dark Brotherhood serving in the Falkreath Sanctuary, pledged to Sithis and the Night Mother.",
        "display_name": "Arcturus - Dark Brotherhood",
        "emotion": "",
        "importance": 0.5,
        "knowledge_key": "falkreath.people.arcturus",
