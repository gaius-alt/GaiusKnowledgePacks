        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Legate Skulnar is an Imperial Legate stationed at Falkreath's Jarl's Longhouse, representing Imperial military authority in the hold. He answers directly to General Tullius.",
        "display_name": "Legate Skulnar - Imperial Legate",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "falkreath.people.skulnar",
        "location": "",
