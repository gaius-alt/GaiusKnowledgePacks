      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Zaria runs Grave Concoctions alongside Nenya — Falkreath's apothecary, keeping the town supplied with remedies while the politics play out around her.",
        "display_name": "Zaria - Steward's Helper",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "falkreath.people.zaria",
        "location": "",
        "tags": [
          "Zaria",
          "Falkreath",
