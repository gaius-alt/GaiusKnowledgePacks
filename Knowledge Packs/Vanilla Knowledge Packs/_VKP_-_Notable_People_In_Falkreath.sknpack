      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Tekla is Helvard's wife and serves as a maid in Dengeir of Stuhn's household. A quiet Nord woman who keeps the former Jarl's home in order.",
        "display_name": "Tekla - Dengeir's Maid",
        "emotion": "",
        "importance": 0.5,
        "knowledge_key": "falkreath.people.tekla",
        "location": "",
        "tags": [
          "Tekla",
          "Falkreath",
