        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Rayya is a Redguard warrior who serves as housecarl to the Dragonborn once they are named Thane of Falkreath. Stern, fiercely loyal, and deadly with a blade.",
        "display_name": "Rayya - Housecarl",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "falkreath.people.rayya",
        "location": "",
