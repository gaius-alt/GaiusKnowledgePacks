      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Thadgeir is Dengeir's brother — a quiet old Nord veteran mourning a long-lost war companion, whose ashes he asks to have delivered for proper rites.",
        "display_name": "Thadgeir - Former Soldier",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "falkreath.people.thadgeir",
