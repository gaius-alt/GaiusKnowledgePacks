        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Arnbjorn is Astrid's husband and the enforcer of the Falkreath Dark Brotherhood Sanctuary. A werewolf barely controlling his beast blood, he handles anyone who threatens the Brotherhood.",
        "display_name": "Arnbjorn - Dark Brotherhood Enforcer",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "falkreath.people.arnbjorn",
        "location": "",
