      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Beitild owns the Iron-Breaker Mine on Dawnstar's west end. Ruthless with her miners, estranged from her husband Leigelf who runs the rival Quicksilver Mine on the other side of town.",
        "display_name": "Beitild - Iron-Breaker Mine",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "pale.people.beitild",
        "location": "",
