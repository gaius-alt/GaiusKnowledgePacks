{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Dawnstar's notable people — Jarl Skald and his court, the rival mine owners, and the priest of Mara who came to investigate the nightmares.",
    "entry_count": 28,
