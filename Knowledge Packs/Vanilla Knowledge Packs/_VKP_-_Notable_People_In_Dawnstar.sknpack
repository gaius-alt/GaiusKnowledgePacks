      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Erandur is the priest of Mara who came to Dawnstar to investigate the nightmares. A former Vaermina cultist — he survived the betrayal at Nightcaller Temple and seeks now to destroy what's left.",
        "display_name": "Erandur - Priest of Mara",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "pale.people.erandur",
        "location": "",
        "tags": [
          "Erandur",
          "Mara",
          "priest",
          "Dawnstar",
          "Nightcaller Temple",
          "Vaermina",
          "former cultist"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Beitild owns the Iron-Breaker Mine on Dawnstar's west end. Ruthless with her miners, estranged from her husband Leigelf who runs the rival Quicksilver Mine on the other side of town.",
        "display_name": "Beitild - Iron-Breaker Mine",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "pale.people.beitild",
        "location": "",
        "tags": [
          "Beitild",
          "Iron-Breaker Mine",
          "Dawnstar",
          "Leigelf",
          "feud"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Leigelf owns the Quicksilver Mine on Dawnstar's east end. Estranged husband of Beitild — they keep competing mines, competing households, and an ongoing feud the whole town can hear.",
        "display_name": "Leigelf - Quicksilver Mine",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "pale.people.leigelf",
        "location": "",
        "tags": [
          "Leigelf",
          "Quicksilver Mine",
          "Dawnstar",
          "Beitild",
          "feud"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Silus Vesuius runs the small Mythic Dawn museum in Dawnstar — his ancestors were part of the cult that killed Emperor Uriel Septim. He's been gathering fragments of Mehrunes' Razor.",
        "display_name": "Silus Vesuius - Museum-keeper",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "pale.people.silus",
        "location": "",
        "tags": [
          "Silus Vesuius",
          "Mythic Dawn",
          "Dawnstar",
          "museum",
          "Razor",
          "Mehrunes Dagon"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Captain Wayfinder works Dawnstar's docks, looking for someone to recover a shipment of Fine-Cut Void Salts his crew lost from the College of Winterhold. Tells anyone who'll listen it has sentimental value.",
        "display_name": "Captain Wayfinder - Docks",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "pale.people.wayfinder",
        "location": "",
        "tags": [
          "Captain Wayfinder",
          "Dawnstar",
          "docks",
          "Night Falls on Sentinel",
          "sea captain"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Rustleif works the forge in Dawnstar with his Redguard wife Seren. Quiet, steady, makes the town's iron.",
        "display_name": "Rustleif - Blacksmith",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "pale.people.rustleif",
        "location": "",
        "tags": [
