      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Erandur is the priest of Mara who came to Dawnstar to investigate the nightmares. A former Vaermina cultist — he survived the betrayal at Nightcaller Temple and seeks now to destroy what's left.",
        "display_name": "Erandur - Priest of Mara",
        "emotion": "",
        "importance": 0.85,
