      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Madena is Skald the Elder's court wizard in Dawnstar — a Breton who has asked the Jarl to let her flee to High Rock entirely, wanting no part of the civil war.",
        "display_name": "Madena - Court Wizard",
        "emotion": "",
