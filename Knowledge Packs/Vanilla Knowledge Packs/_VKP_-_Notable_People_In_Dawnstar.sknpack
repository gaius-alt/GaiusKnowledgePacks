      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Frida runs the Mortar and Pestle in Dawnstar — the town's only alchemist. Older Nord, sells tonics for the nightmares that don't quite work.",
        "display_name": "Frida - Apothecary",
        "emotion": "",
        "importance": 0.55,
