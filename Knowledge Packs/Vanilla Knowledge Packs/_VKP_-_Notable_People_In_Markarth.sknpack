      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Yngvar the Singer is a Nord bard who performs at the Silver-Blood Inn and the Treasury House — his songs are the only beautiful thing in Markarth.",
        "display_name": "Yngvar the Singer - Bard",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.yngvar",
