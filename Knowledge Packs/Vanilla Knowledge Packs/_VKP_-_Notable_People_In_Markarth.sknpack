      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Eltrys is a young Breton who lives in the Warrens — he found documents implicating the Silver-Bloods in a conspiracy and started asking too many questions. His investigation is the thread that unravels Markarth's secrets.",
        "display_name": "Eltrys - Warrens Investigator",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.eltrys",
        "location": "",
        "tags": [
          "Eltrys",
          "Warrens",
          "Markarth",
          "Forsworn Conspiracy",
          "investigator"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Weylin is a Forsworn agent hiding in the Warrens of Markarth — posing as a down-on-his-luck laborer, waiting for Madanach's signal.",
        "display_name": "Weylin - Warrens Forsworn",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.weylin",
        "location": "",
        "tags": [
          "Weylin",
          "Warrens",
          "Markarth",
          "Forsworn",
          "Madanach"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Eola is a worshipper of Namira who lurks around the Hall of the Dead — charming in a hollow way, always watching, always hungry. She recruits the Dragonborn for the Taste of Death.",
        "display_name": "Eola - Namira Worshipper",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.eola",
        "location": "",
        "tags": [
          "Eola",
          "Namira",
          "Markarth",
          "Hall of the Dead",
          "Taste of Death"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Brother Verulus is the priest of Arkay at the Hall of the Dead in Markarth — kind, trusting, and completely unaware that his new follower Eola is leading him to a grisly end.",
        "display_name": "Brother Verulus - Priest of Arkay",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "reach.people.verulus",
        "location": "",
        "tags": [
          "Brother Verulus",
          "Arkay",
          "Hall of the Dead",
          "Markarth",
          "Eola"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Vorstag is a sellsword drinking at the Silver-Blood Inn — Redguard mercenary looking for work, willing to follow anyone who pays.",
        "display_name": "Vorstag - Mercenary",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.vorstag",
        "location": "",
        "tags": [
          "Vorstag",
          "Silver-Blood Inn",
          "Markarth",
