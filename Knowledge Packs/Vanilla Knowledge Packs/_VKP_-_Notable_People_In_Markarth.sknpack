      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Vigilant Tyranus is a Vigilant of Stendarr staying at the Silver-Blood Inn — zealous, suspicious, and on the trail of daedra worshippers.",
        "display_name": "Vigilant Tyranus - Stendarr's Vigilant",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.tyranus",
        "location": "",
