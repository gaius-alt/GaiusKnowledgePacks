        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Endon is a wealthy Breton noble living in Markarth's fashionable district — more money than sense, constantly worried about his household.",
        "display_name": "Endon - Noble",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.endon",
        "location": "",
        "tags": [
          "Endon",
          "Markarth",
          "Breton",
          "noble"
