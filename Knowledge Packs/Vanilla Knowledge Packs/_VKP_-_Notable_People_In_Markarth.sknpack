        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Hogni Red-Arm is a Nord regular at the Silver-Blood Inn — loud, quick to anger, always ready for a fight or a drink.",
        "display_name": "Hogni Red-Arm - Brawler",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "reach.people.hogni",
