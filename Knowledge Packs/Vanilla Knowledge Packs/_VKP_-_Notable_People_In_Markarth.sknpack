        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownMarkarthFaction\") or is_in_faction(actorUUID, \"GuardFactionMarkarth\")",
        "content": "Legate Emmanuel Admand is an Imperial Legion officer stationed at Understone Keep — formal, well-spoken, representing Imperial authority in the Reach.",
        "display_name": "Legate Emmanuel Admand - Imperial Legion",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "reach.people.emand",
        "location": "",
        "tags": [
          "Legate Emmanuel Admand",
          "Imperial Legion",
          "Understone Keep",
          "Markarth"
