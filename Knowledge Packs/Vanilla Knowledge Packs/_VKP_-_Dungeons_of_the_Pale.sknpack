      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "High Gate Ruins is the Nordic citadel of the dragon priest Vokun, on the Pale's western mountains — his mask waits at the back of the keep, beyond his draugr legions.",
        "display_name": "High Gate Ruins",
        "emotion": "",
        "importance": 0.8,
