          "ghosts",
          "ice wraiths"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Forelhost is the Nordic mountain fortress on the Pale–Rift border — the dragon priest Rahgot still rules the deepest chamber, surrounded by his cult's drowned draugr.",
        "display_name": "Forelhost",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.pale.forelhost",
        "location": "",
        "tags": [
