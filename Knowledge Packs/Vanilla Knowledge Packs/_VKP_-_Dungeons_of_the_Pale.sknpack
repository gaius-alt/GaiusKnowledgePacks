{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Nordic ruins, Dwemer ruins, and ice caves of the Pale — including Nightcaller Temple, Frostmere Crypt, and Mzinchaleft.",
    "entry_count": 13,
    "exported_at": "2026-05-18T04:54:36Z",
    "format_version": 2,
    "name": "_VKP - Dungeons of the Pale",
    "npc_groups": [],
    "version": "1.0.0",
    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Nightcaller Temple lies beneath the Tower of Dawn in Dawnstar — once a Vaermina cult, now sealed by sleeping cultists. The Skull of Corruption inside is the source of the town's nightmares.",
        "display_name": "Nightcaller Temple",
        "emotion": "",
        "importance": 0.9,
        "knowledge_key": "dungeon.pale.nightcaller_temple",
        "location": "",
        "tags": [
          "Nightcaller Temple",
          "Pale",
          "Vaermina",
          "Skull of Corruption",
          "Erandur",
          "Tower of Dawn",
          "nightmares"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Frostmere Crypt is the Nordic ruin north of Dawnstar haunted by the Pale Lady. Bandits broke in seeking her sword The Pale Blade, woke the spirit, and most of them never walked out.",
        "display_name": "Frostmere Crypt",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "dungeon.pale.frostmere_crypt",
        "location": "",
        "tags": [
          "Frostmere Crypt",
          "Nordic ruin",
          "Pale",
          "Pale Lady",
          "Eisa Blackthorn",
          "The Pale Blade",
          "Loki Giant-Bane",
          "bandits"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Mzinchaleft is the Dwemer ruin west of Dawnstar where Mjoll the Lioness once lost her sword Grimsever — Falmer hold the upper halls, and worse waits in the deeper machine-floors.",
        "display_name": "Mzinchaleft",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.pale.mzinchaleft",
        "location": "",
        "tags": [
          "Mzinchaleft",
          "Dwemer ruin",
          "Pale",
          "Grimsever",
          "Mjoll",
          "Falmer",
          "Dwarven Centurion"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "The Dawnstar Sanctuary lies hidden beyond a Black Door in a cliffside south of Dawnstar — the old sanctuary of the Dark Brotherhood, abandoned for years and waiting for new tenants.",
        "display_name": "Dawnstar Sanctuary",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.pale.dawnstar_sanctuary",
        "location": "",
        "tags": [
          "Dawnstar Sanctuary",
          "Pale",
          "Dark Brotherhood",
          "Black Door",
          "Astrid"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Yngvild is the Nordic ruin on a peninsula north of Dawnstar — the necromancer Arondil has taken it over, raising ghosts of women he could not have in life.",
        "display_name": "Yngvild",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "dungeon.pale.yngvild",
        "location": "",
        "tags": [
          "Yngvild",
          "Nordic ruin",
          "Pale",
          "Arondil",
