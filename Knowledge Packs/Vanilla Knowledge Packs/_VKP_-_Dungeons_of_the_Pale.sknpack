        "condition_expr": "is_in_faction(actorUUID, \"TownDawnstarFaction\") or is_in_faction(actorUUID, \"GuardFactionDawnstar\")",
        "content": "Tumble Arch Pass is a stone-arch landmark on the road through central Pale — a navigation point for travelers braving the snow.",
        "display_name": "Tumble Arch Pass",
        "emotion": "",
        "importance": 0.5,
        "knowledge_key": "dungeon.pale.tumble_arch_pass",
