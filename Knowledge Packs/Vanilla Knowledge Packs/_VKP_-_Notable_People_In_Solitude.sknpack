      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\") or is_in_faction(actorUUID, \"@SolitudeBardsCollegeFaction\")",
        "content": "Giraud Gemane teaches history at the Bards College. Breton, slightly disorganized, willing to send students chasing relics for the College's collection.",
        "display_name": "Giraud Gemane - History Master",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "haafingar.people.giraud",
