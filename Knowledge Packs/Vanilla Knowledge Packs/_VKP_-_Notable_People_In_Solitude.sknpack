      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Corpulus Vinius runs the Winking Skeever in Solitude with his son Sorex and his daughter Minette. Imperial family, the inn busy at all hours.",
