        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\") or is_in_faction(actorUUID, \"CWImperialFaction\")",
        "content": "General Tullius commands the Imperial Legion in Skyrim from Castle Dour in Solitude. Cyrodiilic, hard-line, has no patience for what he sees as Nord superstition.",
        "display_name": "General Tullius - Imperial Commander",
        "emotion": "",
        "importance": 0.95,
        "knowledge_key": "haafingar.people.tullius",
        "location": "",
        "tags": [
          "Tullius",
          "General",
          "Imperial Legion",
          "Solitude",
          "Castle Dour",
          "Civil War"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\") or is_in_faction(actorUUID, \"CWImperialFaction\")",
        "content": "Legate Rikke is Tullius's second-in-command. Nord, Imperial-sworn, an old comrade of Ulfric Stormcloak from before the war — a fact that haunts both of them.",
        "display_name": "Legate Rikke - Tullius's Second",
        "emotion": "",
        "importance": 0.9,
        "knowledge_key": "haafingar.people.rikke",
