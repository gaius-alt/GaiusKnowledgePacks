      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Taarie runs Radiant Raiment with her sister Endarie. Altmer clothier, polite to customers, ruthless about the bottom line.",
        "display_name": "Taarie - Radiant Raiment",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "haafingar.people.taarie",
        "location": "",
        "tags": [
          "Taarie",
          "Radiant Raiment",
          "Solitude",
          "Altmer",
          "Endarie",
          "clothier"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Endarie is the sharper-tongued of the Radiant Raiment sisters — argues with anyone who can't afford her fashions, and most who can.",
        "display_name": "Endarie - Radiant Raiment (Co-Owner)",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "haafingar.people.endarie",
        "location": "",
        "tags": [
          "Endarie",
          "Radiant Raiment",
          "Solitude",
          "Altmer",
          "Taarie"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Angeline Morrard runs Angeline's Aromatics on Solitude's main street. Older Breton, hasn't heard from her daughter Fura since she joined the Imperial Army and was stationed in Whiterun.",
        "display_name": "Angeline Morrard - Apothecary",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "haafingar.people.angeline",
        "location": "",
        "tags": [
          "Angeline Morrard",
          "Angeline's Aromatics",
          "Solitude",
          "apothecary",
          "Falion",
          "missing daughter"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Vittoria Vici represents the East Empire Company in Solitude and is the Emperor's cousin. She's planning her wedding to Asgeir Snow-Shod — an unusual union of Imperial and Stormcloak families.",
        "display_name": "Vittoria Vici - East Empire Agent",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "haafingar.people.vittoria",
        "location": "",
        "tags": [
          "Vittoria Vici",
          "East Empire Company",
          "Solitude",
          "Imperial",
          "cousin of Titus Mede",
          "wedding"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Orthus Endario manages the East Empire Company's Solitude offices. Imperial, frazzled, fighting against Argonian and Khajiit pirate incursions on his shipping.",
        "display_name": "Orthus Endario - East Empire Manager",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "haafingar.people.orthus",
        "location": "",
        "tags": [
          "Orthus Endario",
          "East Empire Company",
          "Solitude",
          "Imperial",
          "docks"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Styrr tends the Hall of the Dead in Solitude — old Nord priest of Arkay, the one who finally worried that Potema's spirit might walk again.",
        "display_name": "Styrr - Hall of the Dead",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "haafingar.people.styrr",
        "location": "",
        "tags": [
          "Styrr",
          "Hall of the Dead",
          "Solitude",
          "Arkay",
          "Potema"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Rorlund is the head priest of the Temple of the Divines in Solitude. He keeps the eight altars — and looks the other way at the empty Talos alcove.",
        "display_name": "Rorlund - Temple of the Divines",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "haafingar.people.rorlund",
        "location": "",
        "tags": [
          "Rorlund",
          "Temple of the Divines",
          "Solitude",
          "priest",
          "Freir"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Greta in Solitude mourns publicly for her brother Roggvir, who was executed for letting Ulfric escape after killing Torygg. She wants his Amulet of Talos returned — discreetly, since the Thalmor are watching.",
        "display_name": "Greta - Grieving Mother",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "haafingar.people.greta",
        "location": "",
        "tags": [
          "Greta",
          "Solitude",
          "Friga",
          "Shatter-Shield",
          "grief",
          "Windhelm"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Jaree-Ra hangs around outside Solitude offering coin to anyone willing to put out the lighthouse. Argonian wrecker, leader of the Blackblood Marauders alongside his sister Deeja — the job is to beach a ship on the rocks.",
        "display_name": "Jaree-Ra - Wrecker",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "haafingar.people.jaree_ra",
        "location": "",
        "tags": [
          "Jaree-Ra",
          "Solitude",
          "Alik'r",
          "wrecker",
          "Lights Out",
          "Deeja",
          "lighthouse"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Dervenin wanders Solitude's courtyard claiming his master has abandoned him — off visiting a friend in the forbidden wing of the Blue Palace. The townsfolk humor him; he is, in fact, telling the truth about Sheogorath.",
        "display_name": "Dervenin - Mad Priest",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "haafingar.people.dervenin",
