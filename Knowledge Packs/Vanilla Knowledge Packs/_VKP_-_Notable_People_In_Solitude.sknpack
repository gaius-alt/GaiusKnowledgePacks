{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Solitude's people — the Blue Palace court, General Tullius's Legion command at Castle Dour, the Bards College, merchants along the street and docks, and every named resident of the cliff city.",
    "entry_count": 85,
    "exported_at": "2026-05-18T05:00:00Z",
    "format_version": 2,
    "name": "_VKP - Notable People In Solitude",
    "npc_groups": [],
    "version": "1.0.0",
    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Elisif the Fair is the young Jarl of Solitude — widow of High King Torygg, Imperial loyalist, and the Empire's candidate for High Queen of Skyrim. Still finding her footing as a ruler.",
        "display_name": "Elisif the Fair - Jarl of Solitude",
        "emotion": "",
        "importance": 0.95,
        "knowledge_key": "haafingar.people.elisif",
        "location": "",
        "tags": [
          "Elisif the Fair",
          "Jarl",
          "Solitude",
          "High Queen",
          "Torygg",
          "widow",
          "Imperial"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Falk Firebeard is Elisif's steward at the Blue Palace — the practical hand running Solitude while the young Jarl grieves. Imperial-aligned, sharp-eyed.",
        "display_name": "Falk Firebeard - Steward",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "haafingar.people.falk",
        "location": "",
        "tags": [
          "Falk Firebeard",
          "steward",
          "Solitude",
          "Elisif",
          "Blue Palace",
          "governance",
          "administration"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Bryling is a thane of Solitude and one of Elisif's closest advisors. Practical, war-experienced, often opposing the merchant-thane Erikur on the court.",
        "display_name": "Bryling - Thane",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "haafingar.people.bryling",
        "location": "",
        "tags": [
          "Bryling",
          "thane",
          "Solitude",
          "Erikur",
          "Blue Palace",
          "nobility",
          "adviser"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\")",
        "content": "Erikur is the wealthy merchant-thane of Solitude — runs trade through Gulum-Ei at the East Empire Company, and is suspected of darker dealings besides.",
        "display_name": "Erikur - Merchant Thane",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "haafingar.people.erikur",
        "location": "",
        "tags": [
          "Erikur",
