      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownSolitudeFaction\") or is_in_faction(actorUUID, \"GuardFactionHaafingar\") or is_in_faction(actorUUID, \"@SolitudeBardsCollegeFaction\")",
        "content": "Pantea Ateia teaches voice at the Bards College and treats every other instructor as a hack — especially Inge Six-Fingers.",
        "display_name": "Pantea Ateia - Voice Master",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "haafingar.people.pantea",
        "location": "",
