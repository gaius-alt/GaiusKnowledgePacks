          "Moira",
          "cave"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Eldergleam Sanctuary lies in eastern Eastmarch — a small valley around the Eldergleam tree itself, sacred to Kynareth. The priestess Danica of Whiterun seeks a sapling from it to revive the Gildergreen.",
        "display_name": "Eldergleam Sanctuary",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "dungeon.eastmarch.eldergleam_sanctuary",
        "location": "",
