{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Nordic tombs, Dwemer ruins, hot springs, and Falmer warrens of Eastmarch — including Mzulft, Ansilvund, and the giant's camp at Kynesgrove.",
    "entry_count": 14,
    "exported_at": "2026-05-18T04:54:36Z",
    "format_version": 2,
    "name": "_VKP - Dungeons of Eastmarch",
    "npc_groups": [],
    "version": "1.0.0",
    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Mzulft is the great Dwemer ruin in southern Eastmarch — the Synod has been trying to operate its Oculory and failing. Falmer hold most of the lower works.",
        "display_name": "Mzulft",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.eastmarch.mzulft",
        "location": "",
        "tags": [
          "Mzulft",
          "Dwemer ruin",
          "Eastmarch",
          "Synod",
          "Oculory",
          "Crystal",
          "Paratus"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Ansilvund is the Nordic tomb of the lovers Fjori and Holgeir — the necromancer Lu'ah Al-Skaven has overrun it, raising the dead to break Fjori's grave-curse on her husband-killer.",
        "display_name": "Ansilvund",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "dungeon.eastmarch.ansilvund",
        "location": "",
        "tags": [
          "Ansilvund",
