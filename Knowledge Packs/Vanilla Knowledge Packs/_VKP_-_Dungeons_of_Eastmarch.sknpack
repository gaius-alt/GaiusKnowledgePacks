          "Eastmarch",
          "Lu'ah Al-Skaven",
          "Fjori",
          "Holgeir",
          "necromancy",
          "ghost"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Cragwallow Slope is a cave in the eastern Windhelm mountains — necromancers have taken it over, practicing their art far from the city's watch.",
        "display_name": "Cragwallow Slope",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.eastmarch.cragwallow_slope",
        "location": "",
        "tags": [
          "Cragwallow Slope",
          "Eastmarch",
          "necromancers",
          "cave"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Mistwatch is a bandit-held watchtower in central Eastmarch — the leader Fjola runs a kidnapping racket out of it, demanding ransom from desperate husbands.",
        "display_name": "Mistwatch",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.eastmarch.mistwatch",
        "location": "",
        "tags": [
          "Mistwatch",
          "bandit fort",
          "Eastmarch",
          "Christer",
          "Fjola",
          "road raiders",
          "kidnappers"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Steamscorch Mine outside Kynesgrove is Eastmarch's main corundum mine — heated by the hot springs that give the village its steam, feeding the Stormcloak forges.",
        "display_name": "Steamscorch Mine",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.eastmarch.steamscorch_mine",
        "location": "",
        "tags": [
          "Steamscorch Mine",
          "corundum mine",
          "Kynesgrove",
          "Eastmarch",
          "Stormcloak"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Goldenrock Mine at Darkwater Crossing is a small corundum operation in southern Eastmarch — Verner Rock-Chucker and Sondas Drenim keep the small settlement going off this single vein.",
        "display_name": "Goldenrock Mine",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "dungeon.eastmarch.goldenrock_mine",
        "location": "",
        "tags": [
          "Goldenrock Mine",
          "corundum mine",
          "Darkwater Crossing",
          "Eastmarch",
          "Verner",
          "Sondas"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Stony Creek Cave is a small bandit den south of Windhelm — a few raiders preying on the road between Eastmarch and the Rift.",
        "display_name": "Stony Creek Cave",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "dungeon.eastmarch.stony_creek_cave",
        "location": "",
        "tags": [
          "Stony Creek Cave",
