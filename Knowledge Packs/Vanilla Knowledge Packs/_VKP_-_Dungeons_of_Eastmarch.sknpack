          "Gildergreen",
          "Nettlebane"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Gallows Rock is a stone fortress in eastern Eastmarch — Silver Hand stronghold led by Krev the Skinner, where they bring captured werewolves to torture and kill.",
        "display_name": "Gallows Rock",
        "emotion": "",
        "importance": 0.75,
