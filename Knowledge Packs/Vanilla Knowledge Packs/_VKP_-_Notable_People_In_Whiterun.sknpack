      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Eorlund Gray-Mane works the Skyforge above Jorrvaskr — the finest blacksmith in Skyrim by most reckonings. Head of the Gray-Mane clan, with Stormcloak sympathies despite Whiterun's Imperial neutrality.",
        "display_name": "Eorlund Gray-Mane - Skyforge Smith",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "whiterun.people.eorlund",
