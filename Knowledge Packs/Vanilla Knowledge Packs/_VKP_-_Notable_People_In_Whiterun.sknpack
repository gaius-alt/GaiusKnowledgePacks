      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Olfrid Battle-Born heads the Battle-Born clan from his manor in the Plains District — an Imperial sympathizer and Balgruuf's strongest ally. His son Idolaf has joined the Legion.",
