{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Whiterun's notable people — the Jarl's court, the Companions, the great clans of Battle-Born and Gray-Mane, and the shopkeepers everyone in the city knows.",
    "entry_count": 80,
    "exported_at": "2026-05-18T05:00:00Z",
    "format_version": 2,
    "name": "_VKP - Notable People In Whiterun",
    "npc_groups": [],
    "version": "1.0.0",
    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Balgruuf the Greater is the Jarl of Whiterun, ruling from Dragonsreach. A measured man who has tried to stay neutral in the Civil War, though his sympathies lean Imperial. He has three children — Frothar, Dagny, and the troubled Nelkir.",
        "display_name": "Balgruuf the Greater - Jarl of Whiterun",
        "emotion": "",
        "importance": 0.9,
        "knowledge_key": "whiterun.people.balgruuf",
        "location": "",
        "tags": [
          "Balgruuf",
          "Jarl",
          "Whiterun",
          "Dragonsreach",
          "Imperial",
          "Cloud District",
          "Dragonborn",
          "nobility",
          "governance",
          "leadership"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Dagny is Balgruuf's middle child — a young Nord girl who spends her days in Dragonsreach near her father's throne.",
        "display_name": "Dagny - Jarl's Daughter",
        "emotion": "",
        "importance": 0.5,
        "knowledge_key": "whiterun.people.dagny",
        "location": "",
        "tags": [
