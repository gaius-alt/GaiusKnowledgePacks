        "content": "Gerda is the cook in Dragonsreach, working the kitchen to feed the Jarl, his court, and the keep's guards.",
        "display_name": "Gerda - Dragonsreach Cook",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "whiterun.people.gerda",
