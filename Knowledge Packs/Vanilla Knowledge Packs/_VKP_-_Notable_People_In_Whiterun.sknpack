      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Irileth is Balgruuf's Dunmer housecarl, sword-sworn to the Jarl. Sharp-tempered and loyal, she runs the keep's guards and rarely leaves Balgruuf's side.",
        "display_name": "Irileth - Balgruuf's Housecarl",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "whiterun.people.irileth",
