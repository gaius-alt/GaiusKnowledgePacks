      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Hrongar is Balgruuf's hot-tempered brother. He stands near the throne in Dragonsreach and pushes for action against the Stormcloaks — and quietly admires their cause.",
        "display_name": "Hrongar - Balgruuf's Brother",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "whiterun.people.hrongar",
