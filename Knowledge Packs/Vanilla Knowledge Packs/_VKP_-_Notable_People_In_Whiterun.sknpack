        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Fianna is the serving maid in Dragonsreach who tends to the great hall and keeps the keep running day-to-day.",
        "display_name": "Fianna - Dragonsreach Maid",
        "emotion": "",
        "importance": 0.55,
