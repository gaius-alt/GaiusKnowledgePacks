      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Avulstein Gray-Mane is Fralia's son and a Stormcloak soldier. He was captured in the Battle of Whiterun, and his mother seeks help freeing him.",
        "display_name": "Avulstein Gray-Mane - Stormcloak Soldier",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "whiterun.people.avulstein",
