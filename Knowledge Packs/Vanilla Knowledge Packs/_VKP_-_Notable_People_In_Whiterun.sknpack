      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Fralia Gray-Mane is the matriarch of the Gray-Mane clan, living in the Wind District house. Her husband Thorald was captured by the Thalmor, and she desperately seeks his rescue.",
        "display_name": "Fralia Gray-Mane - Gray-Mane Matriarch",
        "emotion": "",
        "importance": 0.6,
