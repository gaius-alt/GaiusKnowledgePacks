      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Olfina Gray-Mane is a young Nord woman of the Gray-Mane clan, caught up in her family's bitter rivalry with the Battle-Borns.",
        "display_name": "Olfina Gray-Mane - Gray-Mane Daughter",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "whiterun.people.olfina",
