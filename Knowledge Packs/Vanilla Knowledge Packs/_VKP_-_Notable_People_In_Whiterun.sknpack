      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Proventus Avenicci is the Jarl's steward in Dragonsreach — an Imperial who manages the city's ledgers and property sales. His daughter Adrianne runs Warmaiden's smithy at the city gates.",
        "display_name": "Proventus Avenicci - Steward",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "whiterun.people.proventus",
