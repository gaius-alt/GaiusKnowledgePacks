        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Frothar is Balgruuf's elder son, still a boy training with wooden swords around Dragonsreach with dreams of becoming a warrior.",
        "display_name": "Frothar - Jarl's Son",
        "emotion": "",
        "importance": 0.5,
        "knowledge_key": "whiterun.people.frothar",
        "location": "",
