        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Nelkir is Balgruuf's youngest son — sullen and withdrawn, he has been influenced by a whispering blade in Dragonsreach's basement that speaks with Mephala's voice.",
        "display_name": "Nelkir - Jarl's Youngest Son",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "whiterun.people.nelkir",
