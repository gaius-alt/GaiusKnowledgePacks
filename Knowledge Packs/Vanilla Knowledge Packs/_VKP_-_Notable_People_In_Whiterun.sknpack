      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Farengar Secret-Fire is Balgruuf's court mage in Dragonsreach. A scholar obsessed with dragons — he has been hoarding rumors of their return since long before Helgen burned.",
        "display_name": "Farengar Secret-Fire - Court Mage",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "whiterun.people.farengar",
        "location": "",
