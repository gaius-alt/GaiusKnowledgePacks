      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Commander Caius is the commander of the Whiterun city guard, based at the Guard Barracks near the main gate. He keeps order in the city and reports to the Jarl.",
        "display_name": "Commander Caius - Guard Commander",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "whiterun.people.caius",
