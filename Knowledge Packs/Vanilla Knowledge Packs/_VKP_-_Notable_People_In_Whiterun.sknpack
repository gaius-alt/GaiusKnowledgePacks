        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Legate Quentin Cipius is an Imperial Legion officer stationed in Dragonsreach after the Civil War, advising the Jarl on Imperial matters.",
        "display_name": "Legate Quentin Cipius - Imperial Legate",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "whiterun.people.quentin",
