        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Honeystrand Cave is a quiet cave in the central Rift where spriggans tend their bees and the bears that wander in for the honey.",
        "display_name": "Honeystrand Cave",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "dungeon.rift.honeystrand_cave",
