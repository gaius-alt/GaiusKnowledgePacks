        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Goldenglow Estate sits on an island just outside Riften — Aringoth runs the apiaries that supply Black-Briar Meadery. The new mercenary force he's hired has Maven Black-Briar furious.",
        "display_name": "Goldenglow Estate",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.rift.goldenglow_estate",
