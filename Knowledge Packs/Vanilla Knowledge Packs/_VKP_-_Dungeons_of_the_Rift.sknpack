{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Nordic tombs, Dwemer ruins, Orc strongholds, dragon lairs, and bandit forts of the Rift — Avanchnzel, Forelhost, Goldenglow, and the foothills of the mountains south of Riften.",
    "entry_count": 17,
    "exported_at": "2026-05-18T04:54:36Z",
    "format_version": 2,
    "name": "_VKP - Dungeons of the Rift",
