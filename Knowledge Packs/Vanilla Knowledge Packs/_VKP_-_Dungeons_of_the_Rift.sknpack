        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Autumnshade Clearing is a small wooded hollow in the Rift — a single spriggan guards a ring of stones where the leaves never fall.",
        "display_name": "Autumnshade Clearing",
        "emotion": "",
        "importance": 0.5,
        "knowledge_key": "dungeon.rift.autumnshade_clearing",
