        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Autumnwatch Tower is a ruined keep in the southern Rift mountains — a dragon roosts at the top, and a Word Wall waits at the foot of its tower.",
        "display_name": "Autumnwatch Tower - Dragon Lair",
        "emotion": "",
        "importance": 0.75,
