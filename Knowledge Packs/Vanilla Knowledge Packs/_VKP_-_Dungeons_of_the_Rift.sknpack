        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Northwind Summit is a high mountain shrine in the Rift's eastern peaks — a dragon holds the summit and the Word Wall it surrounds. Before the dragons returned, the wall was guarded only by skeletons.",
        "display_name": "Northwind Summit - Dragon Lair",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "dungeon.rift.northwind_summit",
