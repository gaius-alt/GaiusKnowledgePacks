    "version": "1.0.0",
    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Ivarstead is the small settlement at the foot of the Seven Thousand Steps. Klimmek climbs the path to deliver supplies to the Greybeards once a month; most other pilgrims need their own legs.",
        "display_name": "Ivarstead",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.rift.ivarstead",
        "location": "",
        "tags": [
          "Ivarstead",
          "Rift",
          "settlement",
          "Klimmek",
          "pilgrims",
          "Seven Thousand Steps",
          "mill"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Shor's Stone is a tiny mining settlement east of Riften — Filnjar runs the forge, and Redbelly Mine below the village pulls iron from a vein the spiders are trying to reclaim.",
        "display_name": "Shor's Stone",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.rift.shors_stone",
        "location": "",
        "tags": [
          "Shor's Stone",
          "Rift",
          "settlement",
          "Redbelly Mine",
          "iron",
          "Filnjar",
          "Sylgja"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Largashbur is the Orc stronghold in the southeastern Rift, besieged by giants and cursed by Malacath until their Chief redeems them. Atub the wise woman tends the rite.",
        "display_name": "Largashbur",
        "emotion": "",
        "importance": 0.8,
        "knowledge_key": "dungeon.rift.largashbur",
        "location": "",
        "tags": [
          "Largashbur",
          "Orc stronghold",
          "Rift",
          "Yamarz",
          "Atub",
          "Malacath",
          "Cursed Tribe",
          "giant"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Avanchnzel is the Dwemer ruin in the eastern Rift — the ghost of the scholar Katria haunts it, retracing the expedition that ended in her death.",
        "display_name": "Avanchnzel",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.rift.avanchnzel",
        "location": "",
        "tags": [
          "Avanchnzel",
          "Dwemer ruin",
          "Rift",
          "Lost to the Ages",
          "Aetherium",
          "Katria",
          "ghost"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Faldar's Tooth is an old keep north of Riften, held by bandits with a kennel of trained dogs. Travelers on the road have learned to circle wide.",
        "display_name": "Faldar's Tooth",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "dungeon.rift.faldars_tooth",
        "location": "",
        "tags": [
          "Faldar's Tooth",
          "bandit fort",
          "Rift",
          "old keep",
          "watchdogs"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Boulderfall Cave is a small necromancer-held cave on the Rift–Eastmarch border. They've been raising skeletons from old graves in the hills above.",
        "display_name": "Boulderfall Cave",
        "emotion": "",
        "importance": 0.55,
        "knowledge_key": "dungeon.rift.boulderfall_cave",
        "location": "",
        "tags": [
          "Boulderfall Cave",
          "Rift",
          "necromancers",
          "skeletons",
          "Stony Creek border"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownRiftenFaction\") or is_in_faction(actorUUID, \"GuardFactionRiften\")",
        "content": "Treva's Watch is an old Imperial border keep in the eastern Rift, now bandit-held. Stalleo, the keep's rightful owner, camps outside hoping to reclaim it.",
        "display_name": "Treva's Watch",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.rift.treva_watch",
        "location": "",
        "tags": [
          "Treva's Watch",
          "bandit fort",
          "Rift",
          "Stalleo",
          "old border keep"
