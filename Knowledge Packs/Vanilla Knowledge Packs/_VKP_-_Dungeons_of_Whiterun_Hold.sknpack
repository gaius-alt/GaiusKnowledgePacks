        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Shimmermist Cave is a Falmer den built into a half-collapsed Dwemer outpost — a sloping cave full of luminous fungus and silent ambushers.",
        "display_name": "Shimmermist Cave",
        "emotion": "",
        "importance": 0.6,
