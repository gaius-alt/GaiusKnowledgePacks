      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "The Western Watchtower west of Whiterun is the Imperial-built outpost where the dragon Mirmulnir attacked — Irileth and the guard fought the first dragon of the new age there.",
        "display_name": "Western Watchtower",
        "emotion": "",
