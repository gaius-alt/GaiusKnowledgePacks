        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Halted Stream Camp is a fortified bandit trench north of Whiterun — mammoth poachers running a small iron mine off a subterranean shaft.",
        "display_name": "Halted Stream Camp",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "dungeon.whiterun.halted_stream_camp",
