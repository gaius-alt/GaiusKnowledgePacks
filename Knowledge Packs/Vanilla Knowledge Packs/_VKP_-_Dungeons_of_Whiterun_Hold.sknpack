      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Embershard Mine is a bandit-held iron mine near Riverwood — collapsed scaffolds, narrow shafts, and good ore for whoever clears it.",
        "display_name": "Embershard Mine",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.whiterun.embershard_mine",
        "location": "",
