      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Silent Moons Camp is a half-ruined Nordic site north of Whiterun — bandits squat among the broken stones, and an old altar still forges Lunar weapons under moonlight.",
        "display_name": "Silent Moons Camp",
        "emotion": "",
        "importance": 0.6,
