    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\") and get_quest_stage(\"MQ102\", false) < 90",
        "content": "Bleak Falls Barrow is the Nordic ruin above Riverwood — a tomb crawling with bandits in the upper chambers and draugr below. The Dragonstone is rumored to lie at its deepest level.",
        "display_name": "Bleak Falls Barrow - Uncleared",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.whiterun.bleakfallsbarrow_uncleared",
        "location": "",
        "tags": [
          "Bleak Falls Barrow",
          "Nordic ruin",
          "Whiterun Hold",
          "Riverwood",
          "draugr",
          "bandits",
          "Dragonstone"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\") and get_quest_stage(\"MQ102\", false) >= 90",
        "content": "Bleak Falls Barrow stands silent above Riverwood now — the bandits and draugr cleared, the Dragonstone taken from the deep chamber where it slept.",
        "display_name": "Bleak Falls Barrow - Cleared",
        "emotion": "",
        "importance": 0.6,
