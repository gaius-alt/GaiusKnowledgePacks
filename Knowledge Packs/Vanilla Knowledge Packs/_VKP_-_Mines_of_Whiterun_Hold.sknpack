      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Embershard Mine pulls iron from the hills above Riverwood — a tunnel system with collapsed supports, wooden scaffolds, and several iron veins running through narrow passages. Bandits hold it; the local jarl would rather they did not.",
        "display_name": "Embershard Mine - Iron",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "mine.whiterun.embershard",
        "location": "",
        "tags": [
          "Embershard Mine",
