          "Whiterun Hold",
          "Riverwood",
          "bandits",
          "veins"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWhiterunFaction\") or is_in_faction(actorUUID, \"GuardFactionWhiterun\")",
        "content": "Halted Stream Camp is a fortified bandit trench north of Whiterun with a long subterranean iron shaft — the same outfit poaches mammoths from the plains, so the mine is only a side trade.",
        "display_name": "Halted Stream Camp - Iron",
        "emotion": "",
