                    "teaching",
                    "education",
                    "scholarship",
                    "kindness"
                ],
                "type": "KNOWLEDGE"
            },
            {
                "always_inject": false,
                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\") or is_in_faction(actorUUID, \"GuardFactionWinterhold\")",
                "content": "Faralda stands at the bridge to the College and decides who may cross. Altmer, master of Destruction, has no time for those who cannot prove a basic spell.",
                "display_name": "Faralda - Gatekeeper",
                "emotion": "",
                "importance": 0.75,
                "knowledge_key": "winterhold.people.faralda",
                "location": "",
