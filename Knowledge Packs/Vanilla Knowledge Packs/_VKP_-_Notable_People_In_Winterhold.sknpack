                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Tandil is an Altmer mage at the College of Winterhold who offers basic training in magic. He can be found wandering the Hall of the Elements.",
                "display_name": "Tandil - College Mage",
                "emotion": "",
                "importance": 0.5,
