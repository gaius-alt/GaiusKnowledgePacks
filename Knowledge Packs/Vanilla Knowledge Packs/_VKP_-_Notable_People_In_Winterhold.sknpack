                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Arniel Gane is a Dunmer mage obsessed with the Dwemer's disappearance. His experiments in recreating the event lead him to seek Keening, the legendary Dwemer dagger, and his research takes a dangerous turn.",
                "display_name": "Arniel Gane - Dwemer Researcher",
                "emotion": "",
                "importance": 0.7,
