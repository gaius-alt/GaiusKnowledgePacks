                    "Winterhold",
                    "exile",
                    "research",
                    "sorcery",
                    "secrecy"
                ],
                "type": "KNOWLEDGE"
            },
            {
                "always_inject": false,
                "condition_expr": "is_in_faction(actorUUID, \"TownWinterholdFaction\") or is_in_faction(actorUUID, \"GuardFactionWinterhold\") or is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\")",
                "content": "Aranea Ienith tends the Shrine of Azura above Winterhold — the last priestess of the Dawn and Dusk Mother in Skyrim. She offers visions to any who reach the statue.",
                "display_name": "Aranea Ienith - Priestess of Azura",
                "emotion": "",
                "importance": 0.85,
                "knowledge_key": "winterhold.people.aranea",
                "location": "",
                "tags": [
                    "Aranea Ienith",
