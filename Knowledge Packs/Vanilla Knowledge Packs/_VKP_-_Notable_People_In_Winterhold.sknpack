                ],
                "type": "KNOWLEDGE"
            },
            {
                "always_inject": false,
                "condition_expr": "is_in_faction(actorUUID, \"TownWinterholdFaction\") or is_in_faction(actorUUID, \"GuardFactionWinterhold\") or is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\")",
                "content": "Nelacar is the Altmer mage renting a back room at the Frozen Hearth. He left the College of Winterhold over the Black Star affair — he was a colleague of Malyn Varen, and knows what really happened to Azura's Star.",
                "display_name": "Nelacar - Mage at the Inn",
                "emotion": "",
                "importance": 0.75,
                "knowledge_key": "winterhold.people.nelacar",
                "location": "",
                "tags": [
                    "Nelacar",
