                    "authority"
                ],
                "type": "KNOWLEDGE"
            },
            {
                "always_inject": false,
                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Ancano is the Thalmor 'advisor' assigned to the College of Winterhold. None of the mages want him there. He watches everything, and most expect he's not just watching.",
                "display_name": "Ancano - Thalmor Advisor",
                "emotion": "",
                "importance": 0.85,
                "knowledge_key": "winterhold.people.ancano",
                "location": "",
                "tags": [
