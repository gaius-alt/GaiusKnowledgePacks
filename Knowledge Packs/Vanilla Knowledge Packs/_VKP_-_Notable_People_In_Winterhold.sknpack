                "always_inject": false,
                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Brelyna Maryon is a shy Dunmer student at the College of Winterhold with a talent for accidentally transforming herself and others. She is one of three College apprentices who may accompany the Dragonborn on their travels.",
                "display_name": "Brelyna Maryon - Apprentice",
                "emotion": "",
                "importance": 0.55,
