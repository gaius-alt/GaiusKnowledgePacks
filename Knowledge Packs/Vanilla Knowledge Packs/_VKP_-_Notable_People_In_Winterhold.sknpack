                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Phinis Gestor teaches Conjuration at the College — atronachs, daedra, and the binding rites. Methodical and unconcerned with mortals' opinions.",
                "display_name": "Phinis Gestor - Conjuration",
                "emotion": "",
                "importance": 0.65,
                "knowledge_key": "winterhold.people.phinis",
                "location": "",
