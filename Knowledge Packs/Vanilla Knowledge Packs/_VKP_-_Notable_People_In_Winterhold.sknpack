                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Quaranir is a member of the Psijic Order who arrives at the College of Winterhold to warn them about the Eye of Magnus. He speaks in riddles and vanishes as mysteriously as he appears.",
                "display_name": "Quaranir - Psijic Order Emissary",
                "emotion": "",
                "importance": 0.8,
                "knowledge_key": "winterhold.people.quaranir",
