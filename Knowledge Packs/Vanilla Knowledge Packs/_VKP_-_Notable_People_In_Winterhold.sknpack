                    "knowledge",
                    "education",
                    "guardianship"
                ],
                "type": "KNOWLEDGE"
            },
            {
                "always_inject": false,
                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Enthir is the Bosmer who deals contraband out of his Hall of Attainment room — anything from a rare ingredient to an outright forbidden tome. Quiet about his customers.",
                "display_name": "Enthir - College Fence",
                "emotion": "",
                "importance": 0.7,
                "knowledge_key": "winterhold.people.enthir",
                "location": "",
                "tags": [
