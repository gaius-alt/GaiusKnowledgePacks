                "condition_expr": "is_in_faction(actorUUID, \"@CollegeofWinterholdFaction\") or is_in_faction(actorUUID, \"TownWinterholdFaction\")",
                "content": "Gelebros is the ghost of a College mage who haunts the Hall of the Elements at night. He drifts through muttering about his time among the living.",
                "display_name": "Gelebros - College Ghost",
                "emotion": "",
                "importance": 0.5,
                "knowledge_key": "winterhold.people.gelebros",
