      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Nilsine Shatter-Shield is the surviving daughter of Tova and Torbjorn. Quiet, withdrawn, mourning her twin Friga in a house where everyone else is also mourning her.",
        "display_name": "Nilsine Shatter-Shield - Surviving Daughter",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "eastmarch.people.nilsine",
        "location": "",
        "tags": [
          "Nilsine Shatter-Shield",
