      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Aventus Aretino is the child who fled Honorhall Orphanage in Riften and barricaded himself in his family's Windhelm house. He performs the Black Sacrament in the upstairs bedroom — calling for the Dark Brotherhood to kill Grelod the Kind.",
        "display_name": "Aventus Aretino - Black Sacrament",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "eastmarch.people.aventus",
        "location": "",
        "tags": [
          "Aventus Aretino",
          "Aretino Residence",
          "Black Sacrament",
          "Dark Brotherhood",
          "Grelod",
          "orphan",
