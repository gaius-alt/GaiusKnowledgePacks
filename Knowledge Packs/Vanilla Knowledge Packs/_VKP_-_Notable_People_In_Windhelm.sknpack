      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Suvaris Atheron manages the Clan Cruel-Sea caravans for the East Empire Company. Dunmer, lives in the Gray Quarter with her brothers Faryl and Aval. Quietly endures the Stormcloak treatment.",
        "display_name": "Suvaris Atheron - Caravan Manager",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "eastmarch.people.suvaris",
