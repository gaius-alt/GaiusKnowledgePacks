      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownWindhelmFaction\") or is_in_faction(actorUUID, \"GuardFactionWindhelm\")",
        "content": "Ambarys Rendar runs the New Gnisis Cornerclub in Windhelm's Gray Quarter. Older Dunmer, bitter about Nord treatment of his people, openly hopes the Stormcloaks lose.",
        "display_name": "Ambarys Rendar - New Gnisis Cornerclub",
        "emotion": "",
        "importance": 0.75,
        "knowledge_key": "eastmarch.people.ambarys",
        "location": "",
