{
  "skyrimnet_knowledge_pack": {
    "author": "_gaius",
    "description": "Caves, Nordic ruins, Orc strongholds, and dragon lairs of Falkreath Hold — including the ruin of Helgen.",
    "entry_count": 12,
    "exported_at": "2026-05-18T04:54:36Z",
    "format_version": 2,
    "name": "_VKP - Dungeons of Falkreath Hold",
    "npc_groups": [],
    "version": "1.0.0",
    "entries": [
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Helgen is the ruined Imperial border town where Alduin first revealed himself — burned to the foundations during what was supposed to be General Tullius's executions. Bandits squat in the rubble now.",
        "display_name": "Helgen - Ruins",
        "emotion": "",
        "importance": 0.85,
        "knowledge_key": "dungeon.falkreath.helgen",
        "location": "",
        "tags": [
          "Helgen",
          "ruins",
          "Falkreath Hold",
          "dragon attack",
          "Alduin",
          "Imperial",
          "border"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Bilegulch Mine is an iron mine in the western mountains of Falkreath taken over by Orc bandits — they work the veins hard, and don't welcome unannounced visitors.",
        "display_name": "Bilegulch Mine",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.falkreath.bilegulch_mine",
        "location": "",
        "tags": [
          "Bilegulch Mine",
          "Orc",
          "iron mine",
          "Falkreath Hold",
          "Orsimer"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Cracked Tusk Keep is a small Orc bandit stronghold in southern Falkreath. Ghunzul leads the raiders here — they're more cutthroats than Orsimer, and have been raiding the road from Helgen.",
        "display_name": "Cracked Tusk Keep",
        "emotion": "",
        "importance": 0.65,
        "knowledge_key": "dungeon.falkreath.cracked_tusk_keep",
        "location": "",
        "tags": [
          "Cracked Tusk Keep",
          "Orc bandits",
          "Falkreath Hold",
          "fortress",
          "Ghunzul"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Halldir's Cairn is the Nordic ruin sealing the wizard-king Halldir — three mages and his draugr retinue keep the deep chamber. His staff lies beside his coffin.",
        "display_name": "Halldir's Cairn",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.falkreath.halldirs_cairn",
        "location": "",
        "tags": [
          "Halldir's Cairn",
          "Nordic ruin",
          "Falkreath Hold",
          "draugr",
          "Halldir",
          "mages"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Sunderstone Gorge is the Nordic ruin held by necromancers in central Falkreath — a Word Wall of Fire Breath waits in its deepest chamber, beyond their summoned dead.",
        "display_name": "Sunderstone Gorge",
        "emotion": "",
        "importance": 0.7,
        "knowledge_key": "dungeon.falkreath.sunderstone_gorge",
        "location": "",
        "tags": [
          "Sunderstone Gorge",
          "Nordic ruin",
          "Falkreath Hold",
          "necromancers",
          "Word of Power",
          "Fire Breath"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Pinewatch looks like an ordinary roadside cottage in eastern Falkreath — its cellar conceals a full bandit hideout run by Rigel Strong-Arm and her crew.",
        "display_name": "Pinewatch",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "dungeon.falkreath.pinewatch",
        "location": "",
        "tags": [
          "Pinewatch",
          "bandit hideout",
          "Falkreath Hold",
          "Rigel Strong-Arm",
          "secret entrance"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "is_in_faction(actorUUID, \"TownFalkreathFaction\") or is_in_faction(actorUUID, \"GuardFactionFalkreath\")",
        "content": "Knifepoint Ridge is a small iron mine in eastern Falkreath now held by bandits — and during Boethiah's Calling, it hides the former Champion of Boethiah in its deepest shaft.",
        "display_name": "Knifepoint Ridge",
        "emotion": "",
        "importance": 0.6,
        "knowledge_key": "dungeon.falkreath.knifepoint_ridge",
        "location": "",
